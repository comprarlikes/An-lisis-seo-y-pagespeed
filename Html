            <div class="social-share-container">
                <p class="share-title">¿Te ha sido útil? ¡Compártelo!</p>
                <div class="social-links">
                     <a href="#" id="share-facebook" class="social-button facebook" target="_blank" rel="noopener noreferrer" aria-label="Compartir en Facebook"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v2.385z"/></svg></a>
                    <a href="#" id="share-twitter" class="social-button twitter" target="_blank" rel="noopener noreferrer" aria-label="Compartir en Twitter"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616v.064c0 2.298 1.634 4.212 3.793 4.649-.65.177-1.354.23-2.06.088.621 1.944 2.423 3.362 4.564 3.404-1.616 1.267-3.638 2.02-5.834 2.02-.378 0-.75-.024-1.114-.065 2.089 1.349 4.58 2.123 7.24 2.123 8.683 0 13.44-7.253 13.44-13.446 0-.205-.005-.409-.013-.612.923-.665 1.722-1.495 2.355-2.438z"/></svg></a>
