    <!-- ===================== SCRIPT UNIFICADO Y FUNCIONAL ================ -->
    <!-- =================================================================== -->
    <script>
    // Toda la lógica JavaScript permanece aquí, sin cambios.
    document.addEventListener('DOMContentLoaded', function() {
        const GOOGLE_PAGESPEED_API_KEY = "";
        const SHAREDCOUNT_API_KEY = "";

        const analyzeButton = document.getElementById('analyze-button');
        const resultsContainer = document.getElementById('results-container');
        const loader = document.getElementById('loader');
        const progressContainer = document.getElementById('progress-container');
        const progressBar = document.getElementById('progress-bar');
        const progressStatus = document.getElementById('progress-status');

        initializeShareButtons(SHAREDCOUNT_API_KEY);
        if (analyzeButton) {
            analyzeButton.addEventListener('click', runAnalysisWithProgress);
        }
        if (resultsContainer) {
            resultsContainer.addEventListener('click', handleAccordion);
        }

        async function runAnalysisWithProgress() {
            let targetUrl = document.getElementById('url-to-analyze').value.trim();
            if (!targetUrl) {
                alert("Por favor, introduce una URL para analizar.");
                return;
            }
            if (!/^https?:\/\//i.test(targetUrl)) {
                targetUrl = 'https://' + targetUrl;
            }
            const keyword = document.getElementById('keyword-input').value.trim();

            resultsContainer.style.display = 'none';
            resultsContainer.innerHTML = '';
            loader.style.display = 'block';
            analyzeButton.disabled = true;
            progressContainer.style.display = 'block';
            updateProgress(5, 'Este proceso puede tardar hasta 1 minuto, por favor espere...');

            let finalHtml = '';
            finalHtml += await analyzeOnPage(targetUrl, keyword);
            updateProgress(33, 'Analizando PageSpeed para Móvil...');
            finalHtml += await analyzeSinglePageSpeed(targetUrl, 'MOBILE');
            updateProgress(66, 'Analizando PageSpeed para Escritorio...');
            finalHtml += await analyzeSinglePageSpeed(targetUrl, 'DESKTOP');
            finalHtml += createFinalMessageHtml(targetUrl);
            
            updateProgress(100, 'Análisis completado ✅');
            loader.style.display = 'none';
            resultsContainer.innerHTML = finalHtml;
            resultsContainer.style.display = 'block';
            analyzeButton.disabled = false;

            setTimeout(() => {
                progressContainer.style.display = 'none';
                updateProgress(0, '');
            }, 2500);

            document.querySelectorAll('#analyzer-wrapper .accordion-toggle').forEach(button => {
                if (!button.classList.contains('active')) button.click();
            });
        }
        
        async function analyzeOnPage(url, keyword) {
            updateProgress(10, 'Analizando SEO On-Page...');
            try {
                const proxyUrl = `https://api.allorigins.win/raw?url=${encodeURIComponent(url)}`;
                const response = await fetch(proxyUrl);
                if (!response.ok) throw new Error('No se pudo acceder a la URL.');
                const html = await response.text();
                const doc = new DOMParser().parseFromString(html, 'text/html');
                
                let resultsHtml = analyzeOnPageSeo(doc);
                if (keyword) resultsHtml += analyzeKeywordDensity(doc, keyword);
                resultsHtml += analyzeContent(doc);
                return resultsHtml;
            } catch (e) {
                return `<div class="analysis-section"><div class="accordion-content open" style="max-height: 500px;"><div class="result-item error"><b>Error en Análisis On-Page:</b> No se pudo acceder a la URL. El análisis de PageSpeed funcionará igualmente.</div></div></div>`;
            }
        }
        
        async function analyzeSinglePageSpeed(url, strategy) {
            try {
                const apiUrl = `https://www.googleapis.com/pagespeedonline/v5/runPagespeed?url=${encodeURIComponent(url)}&strategy=${strategy}&key=${GOOGLE_PAGESPEED_API_KEY}&category=ACCESSIBILITY&category=BEST_PRACTICES&category=PERFORMANCE&category=SEO`;
                const response = await fetch(apiUrl);
                const data = await response.json();
                if (!data.lighthouseResult) throw new Error(data.error ? data.error.message : 'Respuesta inválida');
                return formatPageSpeedResults(data.lighthouseResult, strategy);
            } catch (error) {
                return `<div class="analysis-section"><div class="accordion-content open" style="max-height: 500px;"><div class="result-item error">No se pudo obtener el análisis de PageSpeed para ${strategy}. Error: ${error.message}</div></div></div>`;
            }
        }

        function createFinalMessageHtml(url) {
            const encodedUrl = encodeURIComponent(url);
            const pageSpeedLink = `https://pagespeed.web.dev/analysis?url=${encodedUrl}`;
            return `<div class="final-note"><p>Para un análisis más detallado, consulta los resultados oficiales en Google PageSpeed Insights.</p><a href="${pageSpeedLink}" target="_blank" rel="noopener noreferrer" class="final-note-button">Ver en PageSpeed Insights</a></div>`;
        }

        function analyzeOnPageSeo(doc) {
            const iconSuccess = `<svg class="icon success" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>`;
            const iconError = `<svg class="icon error" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>`;
            let html = `<div class="analysis-section"><button class="accordion-toggle"><div class="accordion-title-group"><span class="icon"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15.5 2H8.6c-.4 0-.8.2-1.1.5-.3.3-.5.7-.5 1.1v12.8c0 .4.2.8.5 1.1.3.3.7.5 1.1.5h9.8c.4 0 .8-.2 1.1-.5.3-.3.5-.7.5-1.1V6.5L15.5 2z"></path><path d="M15 2v5h5"></path><path d="M10 16s.8-1 2-1 2 1 2 1"></path><path d="M12 12a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"></path></svg></span><h5>Análisis SEO On-Page</h5></div><span class="chevron">▼</span></button><div class="accordion-content">`;
            
            const title = doc.querySelector('title')?.innerText || 'No encontrado';
            const titleStatus = title.length >= 30 && title.length <= 60;
            html += `<div class="result-item">${titleStatus ? iconSuccess : iconError}<div><b>Título:</b> ${title} <span class="${titleStatus ? 'success' : 'error'}">(${title.length} caracteres)</span><br><small class="text-light">Recomendación: entre 30 y 60 caracteres.</small></div></div>`;

            const metaDescription = doc.querySelector('meta[name="description"]')?.content || 'No encontrada';
            const descStatus = metaDescription.length >= 70 && metaDescription.length <= 160;
            html += `<div class="result-item">${descStatus ? iconSuccess : iconError}<div><b>Meta Descripción:</b> ${metaDescription} <span class="${descStatus ? 'success' : 'error'}">(${metaDescription.length} caracteres)</span><br><small class="text-light">Recomendación: entre 70 y 160 caracteres.</small></div></div>`;
            
            const h1s = doc.querySelectorAll('h1');
            const h1Status = h1s.length === 1;
            html += `<div class="result-item">${h1Status ? iconSuccess : iconError}<div><b>Encabezados H1:</b> <span class="${h1Status ? 'success-text' : 'error-text'}">${h1s.length}</span> (Ideal: 1)<br>${!h1Status ? '<small class="text-light">Una página debe tener exactamente un H1 para indicar su tema principal.</small>' : ''}</div></div>`;
            
            const imagesWithoutAlt = Array.from(doc.querySelectorAll('img')).filter(img => !img.alt || img.alt.trim() === '');
            const imgStatus = imagesWithoutAlt.length === 0;
            html += `<div class="result-item">${imgStatus ? iconSuccess : iconError}<div><b>Imágenes sin texto alt:</b> <span class="${imgStatus ? 'success-text' : 'error-text'}">${imagesWithoutAlt.length}</span><br>${!imgStatus ? '<small class="text-light">Añade texto alt descriptivo para mejorar la accesibilidad y el SEO.</small>' : ''}</div></div>`;
            
            return html + '</div></div>';
        }

        function analyzeKeywordDensity(doc, keyword) {
            let html = `<div class="analysis-section"><button class="accordion-toggle"><div class="accordion-title-group"><span class="icon"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 2-3 3h-3a4 4 0 0 0-4 4v0"></path><path d="m2 18 3-3h3a4 4 0 0 0 4-4v0"></path><path d="m12 12 6 6"></path><path d="m6 6 6 6"></path></svg></span><h5>Análisis de Palabra Clave</h5></div><span class="chevron">▼</span></button><div class="accordion-content">`;
            const bodyText = doc.body.innerText.toLowerCase();
            const keywordCount = (bodyText.match(new RegExp(keyword.toLowerCase(), "g")) || []).length;
            const titleText = (doc.querySelector('title')?.innerText || '').toLowerCase();
            const h1Text = (doc.querySelector('h1')?.innerText || '').toLowerCase();
            const inTitle = titleText.includes(keyword.toLowerCase());
            const inH1 = h1Text.includes(keyword.toLowerCase());
            
            html += `<div class="result-item"><div><b>Palabra Clave Analizada:</b> "${keyword}"</div></div>`;
            html += `<div class="result-item"><div><b>Apariciones en el texto:</b> ${keywordCount}</div></div>`;
            html += `<div class="result-item">${inTitle ? '✅' : '⚠️'}<div><b>En la etiqueta Title:</b> <span class="${inTitle ? 'success-text' : 'error-text'}">${inTitle ? 'Sí' : 'No'}</span></div></div>`;
            html += `<div class="result-item">${inH1 ? '✅' : '⚠️'}<div><b>En la etiqueta H1:</b> <span class="${inH1 ? 'success-text' : 'error-text'}">${inH1 ? 'Sí' : 'No'}</span></div></div>`;

            return html + '</div></div>';
        }

        function analyzeContent(doc) {
            let html = `<div class="analysis-section"><button class="accordion-toggle"><div class="accordion-title-group"><span class="icon"><svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 6.1H3"></path><path d="M21 12.1H3"></path><path d="M15.1 18.1H3"></path></svg></span><h5>Análisis de Contenido</h5></div><span class="chevron">▼</span></button><div class="accordion-content">`;
            const wordCount = doc.body.innerText.split(/\s+/).length;
            html += `<div class="result-item"><div><b>Recuento de palabras:</b> ${wordCount}</div></div>`;
            const outboundLinks = Array.from(doc.querySelectorAll('a')).filter(a => a.href && (a.href.startsWith('http:') || a.href.startsWith('https:')) && new URL(a.href).hostname !== window.location.hostname).length;
            html += `<div class="result-item"><div><b>Enlaces salientes:</b> ${outboundLinks}</div></div>`;
            return html + '</div></div>';
        }

        function formatPageSpeedResults(lighthouse, strategy) {
            const getScoreColor = (score) => score >= 0.9 ? 'good' : score >= 0.5 ? 'average' : 'poor';
            const icon = strategy === 'MOBILE' ? `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"></rect><line x1="12" y1="18" x2="12.01" y2="18"></line></svg>` : `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>`;
            let html = `<div class="analysis-section"><button class="accordion-toggle"><div class="accordion-title-group">${icon}<h5>Rendimiento (${strategy})</h5></div><span class="chevron">▼</span></button><div class="accordion-content">`;

            const categories = {'performance': 'Rendimiento', 'accessibility': 'Accesibilidad', 'best-practices': 'Prácticas', 'seo': 'SEO'};
            let summaryHtml = '<div class="metric-summary">';
            for (const cat in categories) {
                if (lighthouse.categories[cat]) {
                    const score = lighthouse.categories[cat].score;
                    summaryHtml += `<div><div class="metric-circle metric-${getScoreColor(score)}">${Math.round(score * 100)}</div><div class="metric-label">${categories[cat]}</div></div>`;
                }
            }
            summaryHtml += '</div>';
            
            return html + summaryHtml + '</div></div>';
        }

        function updateProgress(percent, message) {
            progressBar.style.width = percent + '%';
            progressStatus.textContent = message;
        }

        function initializeShareButtons(apiKey) {
            const postUrl = document.location.href;
            const encodedPostUrl = encodeURIComponent(postUrl);
            const postTitle = encodeURIComponent(document.title);
            
            document.getElementById('share-facebook').href = `https://www.facebook.com/sharer/sharer.php?u=${encodedPostUrl}`;
            document.getElementById('share-twitter').href = `https://twitter.com/intent/tweet?url=${encodedPostUrl}&text=${postTitle}`;
            document.getElementById('share-linkedin').href = `https://www.linkedin.com/shareArticle?mini=true&url=${encodedPostUrl}&title=${postTitle}`;
        }

        function handleAccordion(e) {
            const toggleButton = e.target.closest('.accordion-toggle');
            if (toggleButton) {
                toggleButton.classList.toggle('active');
                const content = toggleButton.nextElementSibling;
                content.classList.toggle('open');
                content.style.maxHeight = content.style.maxHeight ? null : content.scrollHeight + 30 + "px";
            }
        }
    });
    </script>
